APP_NAME=Portal do Investidor Evoque
ENV=development
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-super-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
FRONTEND_URL=http://localhost:3020
# Adicione IPs extras separados por vírgula para liberar CORS (acesso via rede local)
# Exemplo: CORS_EXTRA_ORIGINS=http://192.168.1.3:3020,http://192.168.1.10:3020
CORS_EXTRA_ORIGINS=

# MYSQL AZURE
DB_HOST=evoque-database.mysql.database.azure.com
DB_USER=infra
DB_PASSWORD=troque-aqui
DB_NAME=portal-investidor
DB_PORT=3306
DB_SSL_ENABLED=true

# Opcional: se quiser informar a URL diretamente
DATABASE_URL=

STORAGE_DIR=storage/pdfs
MAX_FILE_SIZE_MB=10
